<div class="
    slider-buttons
    {% if hide_desktop %}hidden--desktop{% endif %}
    {% if hide_mobile %}hidden--mobile{% endif %}
  ">
  <button
    type="button"
    class="slider-button slider-button--prev {% if arrows or section.settings.slider_show_arrows %}{% else %}hidden{% endif %}"
    name="prev"
    aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
    aria-controls="Slider-{{ section.id }}"
  >
    {% render 'icon-caret' %}
    <span class="visually-hidden">{{ 'sections.slideshow.previous_slideshow' | t }}</span>
  </button>
  <div
    class="slider-counter slider-counter--dots {% if dots or section.settings.slider_show_dots %}{% else %}hidden{% endif %}"
  ></div>
  <button
    type="button"
    class="slider-button slider-button--next {% if arrows or section.settings.slider_show_arrows %}{% else %}hidden{% endif %}"
    name="next"
    aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
    aria-controls="Slider-{{ section.id }}"
  >
    {% render 'icon-caret' %}
    <span class="visually-hidden">{{ 'sections.slideshow.next_slideshow' | t }}</span>
  </button>

  {%- if section.settings.auto_rotate -%}
    <button
      type="button"
      class="slider-button slider-button__toggle"
      aria-label="{{ 'sections.slideshow.pause_slideshow' | t }}"
      data-pause="false"
    >
      {%- render 'icon-pause' -%}
      {%- render 'icon-play' -%}
    </button>
  {%- endif -%}
</div>
