<div class="
    header__icons
    {% if settings.search_inline %}header__icons--relative{% endif %}
  ">
  {%- for block in section.blocks -%}
    {%- if block.type == 'header_icon' -%}
      <a
        href="{{ block.settings.link }}"
        class="
          {% if block.settings.hide_mobile %} small-hide{% endif %}
          header__icon body body--small focus-inset
        "
      >
        {%- if block.settings.icon != blank -%}
          <img
            src="{{ block.settings.icon | image_url: width: 50 }}"
            class="cart-item__image"
            alt="{{ block.settings.icon | escape }}"
            loading="lazy"
            width="24"
            height="24"
          >
        {%- endif -%}
        <span>
          {{- block.settings.title -}}
        </span>
      </a>
    {%- endif -%}
  {%- endfor -%}

  {%- if settings.search_inline %}
    {%- render 'header_search-inline', input_id: 'Search-In-Modal' -%}
  {% endif %}

  {% render 'header_search', input_id: 'Search-In-Modal' %}

  {%- if shop.customer_accounts_enabled and section.settings.show_customer_accounts -%}
    <a
      href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
      class="
        header__icon--account
        header__icon focus-inset
      "
    >
      {% render 'icon-account' %}

      <span>
        {%- liquid
          if customer
            echo 'customer.account_fallback' | t
          else
            echo 'customer.log_in' | t
          endif
        -%}
      </span>
    </a>
  {%- endif -%}

  <a
    href="{{ routes.cart_url }}"
    class="
      header__icon--cart
      header__icon link focus-inset
    "
    id="cart-icon-bubble"
  >
    {%- render 'icon-cart' -%}
    <span class='visually-hidden'>
      {{- 'sections.cart.cart' | t -}}
    </span>
    <div class="cart-count-bubble">
      <span class="cart-count-bubble__count" aria-hidden="true">{{ cart.item_count }}</span>
      <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
    </div>
  </a>
</div>
