{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}rem;
    padding-bottom: {{ section.settings.padding_bottom }}rem;
  }

  {% if section.settings.margin_bottom %}
    #shopify-section-{{ section.id }} {
      margin-bottom: {{ section.settings.margin_bottom }}rem;
    }
  {% endif %}
{%- endstyle -%}

{%- comment -%}
  Include these settings to support `section_padding`

  {
    "type": "header",
    "content": "Section Padding"
  },
  {
    "type": "range",
    "id": "padding_top",
    "min": 0,
    "max": 4,
    "step": 0.5,
    "unit": "rem",
    "label": "Padding top",
    "default": 2
  },
  {
    "type": "range",
    "id": "padding_bottom",
    "min": 0,
    "max": 4,
    "step": 0.5,
    "unit": "rem",
    "label": "Padding bottom",
    "default": 2
  },
  {
    "type": "range",
    "id": "margin_bottom",
    "min": 0,
    "max": 4,
    "step": 0.5,
    "unit": "rem",
    "label": "Margin bottom",
    "default": 0
  }
{%- endcomment -%}
