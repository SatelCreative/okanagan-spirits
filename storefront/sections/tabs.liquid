{{ 'collection-tabs.css' | asset_url | stylesheet_tag }}

{%- render "section_padding" %}

<div
  id="{{ section.id }}"
  class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding isolate  gradient"
>
  <div class="tabs-container {{ section.settings.layout }}">
    <slider-component>
      <ul
        class="grid slider slider--mobile slider--desktop tabs {% if section.settings.tabs_center %}tabs--center{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {% for block in section.blocks %}
          <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="grid__item slider__slide">
            <a
              href="{{ block.settings.link }}"
              role="tab"
              class="link body link--unstyled collection-tabs__button tabs__button"
              aria-controls="tab{{ forloop.index }}-panel"
              id="tab-{{ forloop.index }}"
              {% if request.path contains block.settings.link %}
                aria-selected="true"
              {% endif %}
            >
              {{ block.settings.title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </slider-component>
  </div>
</div>

{% schema %}
{
  "name": "Tabs",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "info": "t:sections.all.colors.has_cards_info",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "screen-width",
          "label": "Screen width"
        },
        {
          "value": "page-width",
          "label": "Page width"
        },
        {
          "value": "large-width",
          "label": "Large width"
        },
        {
          "value": "full-width",
          "label": "Full width"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "checkbox",
      "id": "tabs_center",
      "label": "Center tabs",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 4,
      "step": 0.5,
      "unit": "rem",
      "label": "Padding top",
      "default": 2
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 4,
      "step": 0.5,
      "unit": "rem",
      "label": "Padding bottom",
      "default": 2
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 4,
      "step": 0.5,
      "unit": "rem",
      "label": "Section margin",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tabs"
    }
  ]
}
{% endschema %}
