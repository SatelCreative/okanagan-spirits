{{ 'section-multicolumn.css' | asset_url | stylesheet_tag }}

{%- render 'section_padding' %}

{%- style -%}
  {% for block in section.blocks %}
    {% if block.settings.show_overlay_on_hover %}
      #{{ section.id }} #Slide-{{ section.id }}-{{ forloop.index }} .media::after {
        --color-background: {{ block.settings.color_scheme.settings.background.red }},{{ block.settings.color_scheme.settings.background.green }},{{ block.settings.color_scheme.settings.background.blue }};
        opacity: 0;
        transition: opacity 0.3s;
      }
      #{{ section.id }} #Slide-{{ section.id }}-{{ forloop.index }}:hover .media::after {
        opacity: {{ block.settings.image_overlay_opacity | divided_by: 100.0 }};
      }
    {% else %}
      #{{ section.id }} #Slide-{{ section.id }}-{{ forloop.index }} .media::after {
        --color-background: {{ block.settings.color_scheme.settings.background.red }},{{ block.settings.color_scheme.settings.background.green }},{{ block.settings.color_scheme.settings.background.blue }};
        opacity: {{ block.settings.image_overlay_opacity | divided_by: 100.0 }};
      }
    {% endif %}
  {% endfor %}

  {% if section.settings.override_image_size %}
    .section-{{ section.id }}-padding .multicolumn-card__image {
      position: relative !important;
      width: {{ section.settings.image_width }}px !important;
    }
    .section-{{ section.id }}-padding .media {
      display: flex !important;
      justify-content: center;
      align-items: center;
    }
  {% endif %}

  {% if section.settings.override_grid_gap %}
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding .grid {
        --column-spacing: {{ section.settings.spacing_grid_horizontal }}px;
      }
    }

    @media screen and (max-width: 749px) {
      .section-{{ section.id }}-padding .grid {
        --column-spacing: {{ section.settings.spacing_grid_horizontal_mobile }}px;
      }
    }
  {% endif %}
{%- endstyle -%}

{%- liquid
  if section.settings.aspect_ratio == 'adapt'
    assign highest_ratio = 0

    for block in section.blocks
      if block.settings.video != blank
        assign ratio = block.settings.video.aspect_ratio | divided_by: 1
      else
        assign ratio = block.settings.image.aspect_ratio | divided_by: 1
      endif

      if ratio > highest_ratio
        assign highest_ratio = ratio
      endif
    endfor
  endif
-%}

<div
  id="{{ section.id }}"
  class="multicolumn color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding  gradient"
>
  <div
    class="{{ section.settings.layout }} isolate {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    {% if settings.animations_reveal_on_scroll %}
      data-cascade
    {% endif %}
  >
    {%- render 'section_header' -%}

    <slider-component>
      <ul
        class="multicolumn-list grid grid--{{ section.settings.columns_desktop | handle }}-col-desktop grid--{{ section.settings.columns_mobile | handle }}-col-mobile slider {% if section.settings.full_width %}slider--full{% endif %} {% if section.settings.enable_desktop_slider %}slider--desktop{% endif %} {% if section.settings.swipe_on_mobile %}slider--mobile{% endif %}"
        id="Slider-{{ section.id }}"
        role="list"
      >
        {%- for block in section.blocks -%}
          {%-
            if block.settings.image == blank
            and block.settings.video == blank
            and block.settings.title == blank
            and block.settings.text == blank
            and block.settings.link_label == blank
          -%}
            {%- continue -%}
          {%- endif -%}

          <li
            id="Slide-{{ section.id }}-{{ forloop.index }}"
            class="
              multicolumn-list__item
              {% if section.settings.overlap %}multicolumn-list__item--overlap{% endif %}
              grid__item
              {% if section.settings.swipe_on_mobile or section.settings.enable_desktop_slider %}slider__slide{% endif %}
              {% if section.settings.column_alignment == 'center' %}center{% endif %}
              {% if settings.animations_reveal_on_scroll %}scroll-trigger animate--slide-in{% endif %}
              color-{{ block.settings.color_scheme }}
            "
            {{ block.shopify_attributes }}
            style="padding: {{ block.settings.card_padding }}rem"
          >
            <div class="multicolumn-card">
              {%- if block.settings.image != blank -%}
                {% capture sizes %}
                  (min-width: 750px) calc(100vw / {{ section.settings.columns_desktop }}), calc(100vw /
                  {{ section.settings.columns_mobile }})
                {% endcapture %}

                {%- capture image -%}
                  <div class="multicolumn-card__image-wrapper">
                    <div
                      class="media media--{{ section.settings.aspect_ratio }}"
                      {% if section.settings.aspect_ratio == 'adapt' %}
                        style="padding-bottom: {{ 1 | divided_by: highest_ratio | times: 100 }}%;"
                      {% endif %}
                    >
                      {%- if block.settings.video != blank -%}
                        {{
                          block.settings.video
                          | video_tag:
                          image_size: '1100x',
                          autoplay: true,
                          loop: true,
                          controls: false,
                          muted: true,
                          class: 'multicolumn-card__image'
                        }}
                      {%- else -%}
                        {{
                          block.settings.image
                          | image_url: width: 3200
                          | image_tag:
                          widths: '200, 300, 500, 750, 1000, 1500, 2000, 2500, 3000',
                          sizes: sizes,
                          class: 'multicolumn-card__image'
                        }}
                      {%- endif -%}
                    </div>
                  </div>
                {%- endcapture -%}

                {% if block.settings.link %}
                  <a href="{{ block.settings.link }}" class="link link--unstyled">
                    {{ image }}
                  </a>
                {% else %}
                  {{ image }}
                {% endif %}
              {%- endif -%}

              <div class="multicolumn-card__info">
                {%- if block.settings.title != blank -%}
                  <h3 class="multicolumn-card__info-title {{ block.settings.heading_size }} {{ block.settings.heading_size_mobile }}">
                    {{ block.settings.title }}
                  </h3>
                {%- endif -%}

                {%- if block.settings.text != blank -%}
                  <div class="multicolumn-card__info-text {{ block.settings.text_style }} {{ block.settings.text_style_mobile }}">
                    {{ block.settings.text }}
                  </div>
                {%- endif -%}

                {%- if block.settings.link_label != blank -%}
                  <a
                    class="{{ block.settings.text_style }} {{ block.settings.text_style_mobile }} {% if block.settings.show_link_as_button %}button{% else %}link{% endif %}"
                    {% if block.settings.link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.link }}"
                    {% endif %}
                  >
                    {{- block.settings.link_label | escape -}}
                  </a>
                {%- endif -%}
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      {%- if section.settings.swipe_on_mobile or section.settings.enable_desktop_slider -%}
        {%- render 'slider_controls', section: section -%}
      {%- endif -%}
    </slider-component>

    {% if section.settings.cta_text != blank %}
      <div class="multicolumn__cta">
        <a href="{{ section.settings.cta_link }}" class="button">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
